// --------------------------
//    LOGS (various /var/log logfiles) → OTLP/HTTP
// --------------------------

// Discover specific files.
local.file_match "varlog" {
  path_targets = [
    { "__path__" = "/var/log/mysql/*.log" },
    { "__path__" = "/var/log/zabbix/*.log" },
    { "__path__" = "/var/log/auth.log" },
    { "__path__" = "/var/log/ufw.log" },
    { "__path_exclude__" = "/var/log/**/*.gz" },
    { "__path_exclude__" = "/var/log/**/*.zip" },
  ]
}

// Tail the discovered files and forward to Loki.
loki.source.file "varlog" {
  targets      = local.file_match.varlog.targets

  // tail_from_end = true // start at the end of the file (new lines only)
  forward_to   = [otelcol.receiver.loki.varlog.receiver]
}

otelcol.receiver.loki "varlog" {
  output {
    logs = [otelcol.processor.resourcedetection.varlog.input]
  }
}

// Host Resource Detection, adds resource attributes to the logs (like hostname).
otelcol.processor.resourcedetection "varlog" {
  detectors = ["system"]
  system {
    hostname_sources = ["os"]
  }

  output {
    logs = [otelcol.processor.transform.varlog.input]
  }
}

// Adds service.name, this helps with drilldown and quering in Grafana.
otelcol.processor.transform "varlog" {
  log_statements {
    context = "log"
    statements = [
      `set(resource.attributes["service.name"], "linux-varlog")`,
      `set(resource.attributes["service.instance.id"], resource.attributes["host.name"])`,
    ]
  }
  output { logs = [otelcol.processor.memory_limiter.varlog.input] }
}

// Memory Limiter Processor, limits the memory usage of the collector. Should always be placed before any batch processor.
otelcol.processor.memory_limiter "varlog" {
  check_interval = "5s"     // How often to check memory usage.
  limit = "128MiB"          // Limit total memory usage to this value.
  spike_limit = "64MiB"    // Allow for short spikes, e.g. during bursts.

  output {
      logs = [otelcol.processor.batch.varlog.input]
  }
}

// Batch Processor, batches the logs before sending them to the OTLP/HTTP exporter.
otelcol.processor.batch "varlog" {
  timeout = "500ms"              // Send at least a batch every timeout (if data is available).
  send_batch_size = 300      // Send directly after this amount is collected, even if the timeout isn't reached yet.
  send_batch_max_size = 600  // Maximum number of items to send in a batch. Batches larger than this will be split up, over timeout value.

  output {
    logs = [otelcol.exporter.otlphttp.varlog.input]
  }
}

// OTLP/HTTP Exporter, exports the logs to the specified endpoint.
otelcol.exporter.otlphttp "varlog" {
  client {
    endpoint = "{{ alloy_endpoint_url }}"
  }
  retry_on_failure {
    enabled = false
  }
}